# ─── CoFoundry Client — Environment Variables ───────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local or any file containing real secrets.

# Base URL of the CoFoundry Express server (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Better Auth — must point to the server (auth endpoints live there)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:5000

# Stripe publishable key (starts with pk_test_ for development)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# ImgBB API key for client-side image uploads
NEXT_PUBLIC_IMGBB_API_KEY=

# Dev only — set to "true" to skip auth-token check in middleware
# Remove or set to "false" before deploying to production
BYPASS_AUTH=true
